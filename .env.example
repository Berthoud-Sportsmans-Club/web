# Initial seed values for DB settings table (used by db:seed-settings only)
# After seeding, these values live in the DB and are managed via the admin CMS.
# MEMBER_CODE must still be set here until db:seed-settings has been run.
MEMBER_CODE=
GATE_CODE_BIKE_PARK=
GATE_CODE_GREEN_EMERGENCY=
GATE_CODE_EAST=

# Neon Postgres (provided by Vercel integration)
DATABASE_URL=

# Vercel Blob (provided by Vercel integration)
BLOB_READ_WRITE_TOKEN=

# Resend (contact form emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com
CONTACT_EMAIL_DEFAULT=
CONTACT_EMAIL_MEMBERSHIP=
CONTACT_EMAIL_EVENTS=
CONTACT_EMAIL_GENERAL=
CONTACT_EMAIL_OTHER=
